{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Chiral-generated RDS instance with CloudFormation state management",
  "Parameters": {
    "DatabaseName": {
      "Type": "String",
      "Description": "Name of the RDS database"
    },
    "InstanceClass": {
      "Type": "String",
      "Description": "RDS instance class"
    },
    "StorageGB": {
      "Type": "Number",
      "Description": "Storage size in GB"
    }
  },
  "Resources": {
    "RDSDatabase": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "DBInstanceIdentifier": { "Ref": "DatabaseName" },
        "Engine": "postgres",
        "EngineVersion": "15.4",
        "DBInstanceClass": { "Ref": "InstanceClass" },
        "AllocatedStorage": { "Ref": "StorageGB" },
        "StorageType": "gp2",
        "StorageEncrypted": true,
        "SkipFinalSnapshot": true,
        "CopyTagsToSnapshot": true,
        "EnableCloudwatchLogsExports": true,
        "VPCSecurityGroups": [
          { "Fn::ImportValue": "DatabaseSecurityGroup" }
        ],
        "DBSubnetGroupName": { "Fn::ImportValue": "DatabaseSubnetGroup" }
      }
    }
  },
  "Outputs": {
    "DatabaseEndpoint": {
      "Description": "RDS database endpoint",
      "Value": { "Fn::GetAtt": ["RDSDatabase", "Endpoint.Address"] }
    },
    "DatabasePort": {
      "Description": "RDS database port", 
      "Value": { "Fn::GetAtt": ["RDSDatabase", "Endpoint.Port"] }
    }
  }
}
