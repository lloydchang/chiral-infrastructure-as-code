{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Chiral-generated AD FS with CloudFormation state management",
  "Parameters": {
    "InstanceType": {
      "Type": "String",
      "Description": "EC2 instance type for AD FS"
    },
    "WindowsVersion": {
      "Type": "String",
      "Description": "Windows Server version"
    }
  },
  "Resources": {
    "ADFSServer": {
      "Type": "AWS::CloudFormation::Stack",
      "Properties": {
        "TemplateURL": { "Fn::Sub": [ "s3://", { "Ref": "AWS::StackName" }, "-templates/adfs-template.json" ] },
        "Parameters": {
          "InstanceType": { "Ref": "InstanceType" },
          "WindowsVersion": { "Ref": "WindowsVersion" }
        },
        "Tags": {
          "Name": { "Ref": "AWS::StackName" },
          "Environment": { "Ref": "Environment" }
        }
      }
    }
  },
  "Outputs": {
    "ADFSInstance": {
      "Description": "AD FS instance ID",
      "Value": { "Fn::GetAtt": ["ADFSServer", "Outputs.InstanceId"] }
    },
    "ADFSDNS": {
      "Description": "AD FS DNS name",
      "Value": { "Fn::GetAtt": ["ADFSServer", "Outputs.PublicDnsName"] }
    }
  }
}
