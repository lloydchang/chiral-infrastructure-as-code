{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Chiral-generated EKS cluster with CloudFormation state management",
  "Parameters": {
    "ClusterName": {
      "Type": "String",
      "Description": "Name of the EKS cluster"
    },
    "NodeInstanceType": {
      "Type": "String",
      "Description": "EC2 instance type for EKS nodes"
    },
    "MinNodes": {
      "Type": "Number",
      "Description": "Minimum number of nodes"
    },
    "MaxNodes": {
      "Type": "Number", 
      "Description": "Maximum number of nodes"
    }
  },
  "Resources": {
    "EKSCluster": {
      "Type": "AWS::EKS::Cluster",
      "Properties": {
        "Name": { "Ref": "ClusterName" },
        "Version": "1.29",
        "RoleArn": { "Fn::GetAtt": ["EKSClusterRole", "Arn"] },
        "ResourcesVpcConfig": {
          "SubnetIds": [
            { "Fn::ImportValue": "PrivateSubnet1" },
            { "Fn::ImportValue": "PrivateSubnet2" },
            { "Fn::ImportValue": "PrivateSubnet3" }
          ]
        }
      }
    },
    "EKSNodeGroup": {
      "Type": "AWS::EKS::Nodegroup",
      "Properties": {
        "ClusterName": { "Ref": "ClusterName" },
        "NodeGroupName": "${ClusterName}-node-group",
        "NodeRole": { "Fn::GetAtt": ["EKSNodeRole", "Arn"] },
        "InstanceTypes": [ { "Ref": "NodeInstanceType" } ],
        "ScalingConfig": {
          "MinSize": { "Ref": "MinNodes" },
          "MaxSize": { "Ref": "MaxNodes" },
          "DesiredSize": { "Fn::GetAtt": ["EKSNodeGroup", "DesiredCapacity"] }
        }
      }
    }
  },
  "Outputs": {
    "ClusterName": {
      "Description": "EKS cluster name",
      "Value": { "Ref": "EKSCluster" }
    },
    "ClusterEndpoint": {
      "Description": "EKS cluster endpoint",
      "Value": { "Fn::GetAtt": ["EKSCluster", "Endpoint"] }
    }
  }
}
