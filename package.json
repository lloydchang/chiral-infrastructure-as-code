{
  "name": "chiral-infrastructure-as-code",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "description": "Chiral Infrastructure as Code: Core-only stateless generation for K8s, Postgres, and ADFS across AWS, Azure, and GCP with zero outer layer dependencies.",
  "main": "dist/main.js",
  "bin": {
    "chiral": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run check-ai-independence && tsc",
    "build:core-only": "tsc --project tsconfig.core.json",
    "compile": "ts-node src/main.ts",
    "test": "NODE_OPTIONS=\"--no-warnings\" jest --no-watch",
    "test:watch": "NODE_OPTIONS=\"--no-warnings\" jest --watch",
    "test:coverage": "NODE_OPTIONS=\"--no-warnings\" jest --coverage --no-watch",
    "test:core": "jest --testPathPatterns=\"src/__tests__/(cost-analysis|validation|terraform-adapter|import|intent|main|migration|compliance|hardware-map|generation-integration|terraform-integration).test.ts\" --no-watch",
    "test:security": "NODE_OPTIONS=\"--no-warnings\" jest --testPathPatterns=security --no-watch",
    "security:scan": "trufflehog filesystem .",
    "security:deps": "npm audit",
    "security:all": "npm run test:security && npm run security:deps && npm run security:scan",
    "validate:local": "ts-node src/main.ts validate -c chiral.config.ts",
    "check": "npm run test:core && npm run security:all && npm run validate:local && npm run check-ai-independence",
    "check-ai-independence": "node scripts/check-ai-independence.js",
    "enforce-core-isolation": "node scripts/enforce-core-isolation.js",
    "prebuild": "npm run enforce-core-isolation",
    "pretest": "npm run enforce-core-isolation",
    "prepublish": "npm run enforce-core-isolation",
    "cdk": "cdk",
    "deploy-aws": "cdk deploy",
    "diff-aws": "cdk diff",
    "destroy-aws": "cdk destroy",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "iac",
    "infrastructure-as-code",
    "amazon",
    "amazon web services",
    "aws",
    "cdk",
    "cloudformation",
    "microsoft",
    "azure",
    "bicep",
    "arm",
    "gcp",
    "gcloud",
    "google cloud",
    "infrastructure manager",
    "terraform",
    "blueprint",
    "kubernetes",
    "postgres",
    "adfs"
  ],
  "author": "lloydchang",
  "repository": {
    "type": "git",
    "url": "https://github.com/lloydchang/chiral-infrastructure-as-code"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.130.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@aws-cdk/lambda-layer-kubectl-v26": "^2.0.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1003.0",
    "@aws-sdk/client-qbusiness": "^3.1003.0",
    "@azure/openai": "^2.0.0",
    "@google-cloud/aiplatform": "^6.5.0",
    "@google-cloud/vertexai": "^1.10.0",
    "aws-cdk-lib": "^2.130.0",
    "commander": "^12.0.0",
    "constructs": "^10.0.0",
    "hcl2-parser": "^1.0.3",
    "jose": "^6.2.0",
    "js-yaml": "^4.1.1",
    "openai": "^6.27.0",
    "winston": "^3.19.0"
  }
}
