{
  "name": "chiral-infrastructure-as-code",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "description": "Chiral Pattern: Syncing K8s, Postgres, and AD FS across AWS and Azure.",
  "main": "dist/main.js",
  "bin": {
    "chiral": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "compile": "ts-node src/main.ts",
    "test": "NODE_OPTIONS=\"--no-warnings\" jest --no-watch",
    "test:watch": "NODE_OPTIONS=\"--no-warnings\" jest --watch",
    "test:coverage": "NODE_OPTIONS=\"--no-warnings\" jest --coverage --no-watch",
    "test:security": "NODE_OPTIONS=\"--no-warnings\" jest --testPathPatterns=security --no-watch",
    "security:scan": "trufflehog filesystem .",
    "security:deps": "npm audit",
    "security:all": "npm run test:security && npm run security:deps && npm run security:scan",
    "validate:local": "ts-node src/main.ts validate -c chiral.config.ts",
    "check": "npm run test && npm run security:all && npm run validate:local",
    "cdk": "cdk",
    "deploy-aws": "cdk deploy",
    "diff-aws": "cdk diff",
    "destroy-aws": "cdk destroy",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "iac",
    "infrastructure-as-code",
    "aws",
    "azure",
    "gcp",
    "cdk",
    "bicep",
    "terraform",
    "kubernetes",
    "postgres",
    "adfs"
  ],
  "author": "Lloyd Chang",
  "repository": {
    "type": "git",
    "url": "https://github.com/lloydchang/chiral-infrastructure-as-code"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.130.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@aws-cdk/lambda-layer-kubectl-v26": "^2.0.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1003.0",
    "@aws-sdk/client-qbusiness": "^3.1003.0",
    "@azure/openai": "^2.0.0",
    "@google-cloud/aiplatform": "^6.5.0",
    "aws-cdk-lib": "^2.130.0",
    "commander": "^12.0.0",
    "constructs": "^10.0.0",
    "hcl2-parser": "^1.0.3",
    "js-yaml": "^4.1.1"
  }
}
